# Copy this file to .env.local and fill in your values

# Google OAuth Client ID (from Google Cloud Console → APIs & Services → Credentials)
# Make sure to add your domain to Authorized JavaScript Origins
# Required scopes: contacts.readonly, drive.file
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# Facebook App ID (from developers.facebook.com → My Apps)
# Required permissions: public_profile, user_friends
# Note: user_friends only returns friends who have also authorized your app
VITE_FACEBOOK_APP_ID=your_facebook_app_id_here

# Admin email to share tracking spreadsheets with (granted owner/writer access)
VITE_ADMIN_EMAIL=your_admin_email_here
